# =============================================================================
# AgentDock — Environment Variables Reference
# Copy this file to .env and fill in your values.
#
# LEGAL NOTICE:
# AgentDock is an independent project, not affiliated with Anthropic PBC.
# You are responsible for complying with Anthropic's Terms of Service.
# See docs/tos-compliance.md for guidance on which auth method to use.
# Using ANTHROPIC_API_KEY (Anthropic Console) is recommended for automation.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (choose one method)
# -----------------------------------------------------------------------------

# RECOMMENDED: Anthropic Console API key (console.anthropic.com → API Keys)
# When set, no `claude login` is needed. Pay-per-use billing. ToS-compliant
# for always-on automated agents.
ANTHROPIC_API_KEY=

# AUTH_MODE controls the OAuth login flow used when ANTHROPIC_API_KEY is not set.
#   console      → Anthropic Console OAuth (API billing) — recommended
#   subscription → claude.ai subscription OAuth — personal interactive use only
#   apikey       → requires ANTHROPIC_API_KEY to be set; errors if missing
AUTH_MODE=console

# -----------------------------------------------------------------------------
# Channel Configuration (required)
# -----------------------------------------------------------------------------

# Which messaging channel to use: telegram | discord | none
CHANNEL=telegram

# Telegram: create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=

# Discord: create a bot in the Discord Developer Portal and paste the token here
DISCORD_BOT_TOKEN=
# Discord: restrict the bot to a specific text channel (recommended)
DISCORD_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Data Volume
# -----------------------------------------------------------------------------

# Host path to mount as the persistent data volume
# This directory stores auth credentials, config, projects, and logs.
# It must survive container restarts — back this up!
DATA_PATH=./agentdock-data

# -----------------------------------------------------------------------------
# Web UI (optional, for first-run auth guidance)
# -----------------------------------------------------------------------------

# Set to true to expose a minimal status page during first-run setup
WEBUI_ENABLED=false
WEBUI_PORT=8080

# -----------------------------------------------------------------------------
# Git Sync (optional)
# -----------------------------------------------------------------------------

# Remote URL to sync the project workspace to (GitHub, GitLab, Forgejo, etc.)
GIT_SYNC_URL=

# Personal access token with repo write permissions
GIT_SYNC_TOKEN=

# Git author identity for commits made by AgentDock
GIT_USER_NAME=AgentDock
GIT_USER_EMAIL=agentdock@localhost
