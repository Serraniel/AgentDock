# =============================================================================
# AgentDock — Environment Variables Reference
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Channel Configuration (required)
# -----------------------------------------------------------------------------

# Which messaging channel to use: telegram | discord | none
CHANNEL=telegram

# Telegram: create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=

# Discord: create a bot in the Discord Developer Portal and paste the token here
DISCORD_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Data Volume
# -----------------------------------------------------------------------------

# Host path to mount as the persistent data volume
# This directory stores auth credentials, config, projects, and logs.
# It must survive container restarts — back this up!
DATA_PATH=./agentdock-data

# -----------------------------------------------------------------------------
# Web UI (optional, for first-run auth guidance)
# -----------------------------------------------------------------------------

# Set to true to expose a minimal status page during first-run setup
WEBUI_ENABLED=false
WEBUI_PORT=8080

# -----------------------------------------------------------------------------
# Git Sync (optional)
# -----------------------------------------------------------------------------

# Remote URL to sync the project workspace to (GitHub, GitLab, Forgejo, etc.)
GIT_SYNC_URL=

# Personal access token with repo write permissions
GIT_SYNC_TOKEN=

# Git author identity for commits made by AgentDock
GIT_USER_NAME=AgentDock
GIT_USER_EMAIL=agentdock@localhost
